# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Model selection ---
AETHER_MODEL=claude-opus-4-7
AETHER_FAST_MODEL=claude-haiku-4-5-20251001

# --- Storage ---
AETHER_HOME=/data
AETHER_DB_PATH=/data/state.db
AETHER_LOG_LEVEL=INFO

# --- Gateway: Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=         # comma-separated chat IDs

# --- Gateway: Discord ---
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=          # comma-separated user IDs

# --- Self-evolution ---
AETHER_EVOLVE_ENABLED=true
AETHER_EVOLVE_MIN_USES=5        # min skill usages before considered for evolution

# --- Memory ---
AETHER_MEMORY_NUDGE_INTERVAL=20 # message-count interval for memory curation nudge
AETHER_SUMMARIZE_AFTER=40       # summarize old turns after this many messages

# --- Behavior ---
AETHER_PERSONALITY=default
AETHER_MAX_TURNS=200
